# ═══════════════════════════════════════════════════════════════════
#  MasterCodeWeb — .htaccess
#  Apache / LiteSpeed · Hostinger shared hosting
#  Canonical domain: https://www.mastercodeweb.com
# ═══════════════════════════════════════════════════════════════════


# ── Globals ────────────────────────────────────────────────────────────────────
AddDefaultCharset UTF-8
DirectoryIndex    index.html
ServerSignature   Off

# Prevent directory listing when no index file is present
Options -Indexes


# ══════════════════════════════════════════════════════════════════════
#  ACCESS CONTROL  (evaluated before any redirect)
# ══════════════════════════════════════════════════════════════════════

# Dotfiles — .git, .env, .DS_Store, etc.
<FilesMatch "^\.">
  Require all denied
</FilesMatch>

# Block _templates directory, dot-paths (.git, .env, .claude…), and common attack targets
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule ^_templates(/|$) - [F,L]

  # Block any path segment starting with a dot, except .well-known (ACME / Let's Encrypt)
  RewriteRule (^|/)\.(?!well-known) - [F,L]

  # Block WordPress, admin panels, package manager files, and other common attack surfaces
  RewriteRule ^(wp-admin|wp-login|xmlrpc\.php|phpmyadmin|adminer|composer\.(json|lock)|package(-lock)?\.json|yarn\.lock)(/|$) - [F,L]

  # Block direct access to Composer vendor directory and Stripe SDK
  RewriteRule ^vendor(/|$) - [F,L]

  # Block config/ directory (bootstrap.php, stripe.php, .env derivatives)
  RewriteRule ^config(/|$) - [F,L]

  # Block storage/ directory (logs, uploads, etc.)
  RewriteRule ^storage(/|$) - [F,L]

  # Block config files in api/ (config, debug helpers, etc.)
  RewriteRule ^api/config\.php$ - [F,L]
  # Excepción temporal — diagnóstico de checkout (eliminar junto con el archivo)
  RewriteRule ^api/debug-checkout\.php$ - [L]
  RewriteRule ^api/debug- - [F,L]
</IfModule>


# ══════════════════════════════════════════════════════════════════════
#  CANONICAL REDIRECT
#  All four variants (http/https × www/non-www) resolve in ONE 301.
# ══════════════════════════════════════════════════════════════════════

<IfModule mod_rewrite.c>
  RewriteEngine On
  Options +FollowSymLinks

  # Stripe webhook — bypass canonical redirect (Stripe does not follow 3xx)
  RewriteCond %{REQUEST_URI} ^/api/webhook\.php$
  RewriteRule ^ - [L]

  # If HTTP  OR  host is not www → redirect to canonical https://www.*
  RewriteCond %{HTTPS} off [OR]
  RewriteCond %{HTTP_HOST} !^www\. [NC]
  RewriteRule ^ https://www.mastercodeweb.com%{REQUEST_URI} [R=301,L,QSA]

  # Strip trailing slash from non-directory URLs
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.+)/$ /$1 [R=301,L]
</IfModule>


# ══════════════════════════════════════════════════════════════════════
#  ERROR PAGES
# ══════════════════════════════════════════════════════════════════════

ErrorDocument 404 /404.html


# ══════════════════════════════════════════════════════════════════════
#  COMPRESSION
#  Brotli preferred (LiteSpeed native); gzip as universal fallback.
# ══════════════════════════════════════════════════════════════════════

<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS \
    text/html text/plain text/xml text/css \
    text/javascript application/javascript application/json \
    image/svg+xml font/woff2
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE \
    text/html text/plain text/xml text/css \
    text/javascript application/javascript application/json \
    image/svg+xml font/woff font/woff2
</IfModule>

# Downstream caches must store separate copies per encoding
<IfModule mod_headers.c>
  <FilesMatch "\.(html|css|js|json|xml|svg|svgz|woff|woff2)$">
    Header append Vary Accept-Encoding
  </FilesMatch>
</IfModule>


# ══════════════════════════════════════════════════════════════════════
#  CACHING
#  mod_expires sets the Expires header.
#  mod_headers adds Cache-Control (preferred by modern browsers/CDNs).
#  Both are set so either mechanism is sufficient on its own.
# ══════════════════════════════════════════════════════════════════════

<IfModule mod_expires.c>
  ExpiresActive On

  # Fingerprinted / truly immutable assets
  ExpiresByType image/x-icon           "access plus 1 year"
  ExpiresByType font/woff              "access plus 1 year"
  ExpiresByType font/woff2             "access plus 1 year"

  # Images — long-lived; use ?v=n on the URL when replacing a file
  ExpiresByType image/webp             "access plus 6 months"
  ExpiresByType image/svg+xml          "access plus 6 months"
  ExpiresByType image/png              "access plus 6 months"
  ExpiresByType image/jpeg             "access plus 6 months"

  # CSS & JS — append ?v=n in HTML when deploying updates
  ExpiresByType text/css               "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType text/javascript        "access plus 1 month"

  # HTML — short; revalidate on every visit
  ExpiresByType text/html              "access plus 1 hour"
  ExpiresByType application/xhtml+xml  "access plus 1 hour"

  # Data — never cache dynamic/data responses
  ExpiresByType application/json       "access plus 0 seconds"
  ExpiresByType text/xml               "access plus 0 seconds"
  ExpiresByType application/xml        "access plus 0 seconds"
</IfModule>

<IfModule mod_headers.c>
  # Fonts & favicon — truly immutable; cache forever
  <FilesMatch "\.(ico|woff|woff2)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Images — 6 months
  <FilesMatch "\.(webp|svg|svgz|png|jpg|jpeg|gif)$">
    Header set Cache-Control "public, max-age=15552000"
  </FilesMatch>

  # CSS & JS — 1 month
  <FilesMatch "\.(css|js|mjs)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>

  # HTML — 1 hour, must revalidate before serving stale
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=3600, must-revalidate"
  </FilesMatch>
</IfModule>


# ══════════════════════════════════════════════════════════════════════
#  ETAGS
#  Disabled — Expires + Cache-Control cover all caching needs.
#  ETags from multi-server setups produce inode mismatches.
# ══════════════════════════════════════════════════════════════════════

FileETag None
<IfModule mod_headers.c>
  Header unset ETag
</IfModule>


# ══════════════════════════════════════════════════════════════════════
#  SECURITY HEADERS
# ══════════════════════════════════════════════════════════════════════

<IfModule mod_headers.c>
  # Prevent this site from being embedded in iframes on other domains
  Header always set X-Frame-Options "SAMEORIGIN"

  # Stop browsers from MIME-sniffing away from the declared Content-Type
  Header always set X-Content-Type-Options "nosniff"

  # Send origin on same-origin requests; only the origin on cross-origin
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # Disable browser features this site does not use
  Header always set Permissions-Policy \
    "accelerometer=(), autoplay=(), browsing-topics=(), camera=(), display-capture=(), geolocation=(), gyroscope=(), interest-cohort=(), magnetometer=(), microphone=(), payment=(), picture-in-picture=(), publickey-credentials-get=(), usb=()"

  # Strip server fingerprint
  Header always unset X-Powered-By
  Header always unset Server

  # HTTPS Strict Transport Security — force HTTPS for 1 year
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

  # Content Security Policy
  # challenges.cloudflare.com requerido para Cloudflare Turnstile
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com https://cdn.jsdelivr.net https://js.stripe.com https://challenges.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://www.google-analytics.com https://www.googletagmanager.com https://api.emailjs.com https://api.stripe.com https://challenges.cloudflare.com; frame-src https://www.google.com https://www.youtube.com https://js.stripe.com https://hooks.stripe.com https://challenges.cloudflare.com; form-action 'self' https://checkout.stripe.com; object-src 'none'; base-uri 'self'; upgrade-insecure-requests;"
</IfModule>


# ══════════════════════════════════════════════════════════════════════
#  SENSITIVE FILE BLOCKING
#  Deny direct HTTP access to backup, temp, config, and archive files.
# ══════════════════════════════════════════════════════════════════════

<FilesMatch "\.(bak|sql|log|conf|orig|tmp|swp|swo|sh|py|rb|pl|gz|tar|zip|rar|7z)$">
  Require all denied
</FilesMatch>


# ══════════════════════════════════════════════════════════════════════
#  MIME TYPES
#  Explicit declarations prevent Apache from guessing wrong MIME types,
#  which can trigger Content-Type-Options blocks in some browsers.
# ══════════════════════════════════════════════════════════════════════

<IfModule mod_mime.c>
  AddType image/webp             .webp
  AddType image/svg+xml          .svg .svgz
  AddType font/woff              .woff
  AddType font/woff2             .woff2
  AddType application/javascript .js .mjs
  AddType text/css               .css
  AddType application/json       .json
</IfModule>
