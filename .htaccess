# ═══════════════════════════════════════════════════════════════════
#  MasterCodeWeb — .htaccess
#  Apache / LiteSpeed · Hostinger shared hosting
#  Canonical domain: https://www.mastercodeweb.com
# ═══════════════════════════════════════════════════════════════════


# ── Globals ────────────────────────────────────────────────────────────────────
AddDefaultCharset UTF-8
DirectoryIndex    index.html
ServerSignature   Off

# Prevent directory listing when no index file is present
Options -Indexes


# ══════════════════════════════════════════════════════════════════════
#  ACCESS CONTROL  (evaluated before any redirect)
# ══════════════════════════════════════════════════════════════════════

# Dotfiles — .git, .env, .DS_Store, etc.
<FilesMatch "^\.">
  Require all denied
</FilesMatch>

# Reference-only directory — never serve _templates/ publicly
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule ^_templates(/|$) - [F,L]
</IfModule>


# ══════════════════════════════════════════════════════════════════════
#  CANONICAL REDIRECT
#  All four variants (http/https × www/non-www) resolve in ONE 301.
# ══════════════════════════════════════════════════════════════════════

<IfModule mod_rewrite.c>
  RewriteEngine On
  Options +FollowSymLinks

  # If HTTP  OR  host is not www → redirect to canonical https://www.*
  RewriteCond %{HTTPS} off [OR]
  RewriteCond %{HTTP_HOST} !^www\. [NC]
  RewriteRule ^ https://www.mastercodeweb.com%{REQUEST_URI} [R=301,L,QSA]

  # Strip trailing slash from non-directory URLs
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.+)/$ /$1 [R=301,L]
</IfModule>


# ══════════════════════════════════════════════════════════════════════
#  ERROR PAGES
# ══════════════════════════════════════════════════════════════════════

ErrorDocument 404 /404.html


# ══════════════════════════════════════════════════════════════════════
#  COMPRESSION
#  Brotli preferred (LiteSpeed native); gzip as universal fallback.
# ══════════════════════════════════════════════════════════════════════

<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS \
    text/html text/plain text/xml text/css \
    text/javascript application/javascript application/json \
    image/svg+xml font/woff2
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE \
    text/html text/plain text/xml text/css \
    text/javascript application/javascript application/json \
    image/svg+xml font/woff font/woff2
</IfModule>

# Downstream caches must store separate copies per encoding
<IfModule mod_headers.c>
  <FilesMatch "\.(html|css|js|json|xml|svg|svgz|woff|woff2)$">
    Header append Vary Accept-Encoding
  </FilesMatch>
</IfModule>


# ══════════════════════════════════════════════════════════════════════
#  CACHING
#  mod_expires sets the Expires header.
#  mod_headers adds Cache-Control (preferred by modern browsers/CDNs).
#  Both are set so either mechanism is sufficient on its own.
# ══════════════════════════════════════════════════════════════════════

<IfModule mod_expires.c>
  ExpiresActive On

  # Fingerprinted / truly immutable assets
  ExpiresByType image/x-icon           "access plus 1 year"
  ExpiresByType font/woff              "access plus 1 year"
  ExpiresByType font/woff2             "access plus 1 year"

  # Images — long-lived; use ?v=n on the URL when replacing a file
  ExpiresByType image/webp             "access plus 6 months"
  ExpiresByType image/svg+xml          "access plus 6 months"
  ExpiresByType image/png              "access plus 6 months"
  ExpiresByType image/jpeg             "access plus 6 months"

  # CSS & JS — append ?v=n in HTML when deploying updates
  ExpiresByType text/css               "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType text/javascript        "access plus 1 month"

  # HTML — short; revalidate on every visit
  ExpiresByType text/html              "access plus 1 hour"
  ExpiresByType application/xhtml+xml  "access plus 1 hour"

  # Data — never cache dynamic/data responses
  ExpiresByType application/json       "access plus 0 seconds"
  ExpiresByType text/xml               "access plus 0 seconds"
  ExpiresByType application/xml        "access plus 0 seconds"
</IfModule>

<IfModule mod_headers.c>
  # Fonts & favicon — truly immutable; cache forever
  <FilesMatch "\.(ico|woff|woff2)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Images — 6 months
  <FilesMatch "\.(webp|svg|svgz|png|jpg|jpeg|gif)$">
    Header set Cache-Control "public, max-age=15552000"
  </FilesMatch>

  # CSS & JS — 1 month
  <FilesMatch "\.(css|js|mjs)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>

  # HTML — 1 hour, must revalidate before serving stale
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=3600, must-revalidate"
  </FilesMatch>
</IfModule>


# ══════════════════════════════════════════════════════════════════════
#  ETAGS
#  Disabled — Expires + Cache-Control cover all caching needs.
#  ETags from multi-server setups produce inode mismatches.
# ══════════════════════════════════════════════════════════════════════

FileETag None
<IfModule mod_headers.c>
  Header unset ETag
</IfModule>


# ══════════════════════════════════════════════════════════════════════
#  SECURITY HEADERS
# ══════════════════════════════════════════════════════════════════════

<IfModule mod_headers.c>
  # Prevent this site from being embedded in iframes on other domains
  Header always set X-Frame-Options "SAMEORIGIN"

  # Stop browsers from MIME-sniffing away from the declared Content-Type
  Header always set X-Content-Type-Options "nosniff"

  # Send origin on same-origin requests; only the origin on cross-origin
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # Disable browser features this site does not use
  Header always set Permissions-Policy \
    "geolocation=(), microphone=(), camera=(), payment=(), usb=()"

  # Strip server fingerprint
  Header always unset X-Powered-By
  Header always unset Server
</IfModule>


# ══════════════════════════════════════════════════════════════════════
#  MIME TYPES
#  Explicit declarations prevent Apache from guessing wrong MIME types,
#  which can trigger Content-Type-Options blocks in some browsers.
# ══════════════════════════════════════════════════════════════════════

<IfModule mod_mime.c>
  AddType image/webp             .webp
  AddType image/svg+xml          .svg .svgz
  AddType font/woff              .woff
  AddType font/woff2             .woff2
  AddType application/javascript .js .mjs
  AddType text/css               .css
  AddType application/json       .json
</IfModule>
