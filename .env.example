# ═══════════════════════════════════════════════════════
#  MasterCodeWeb — .env.example  [plantilla · SÍ va a git]
#  Copia como .env y rellena los valores reales.
#  .env NUNCA debe subirse a git.
# ═══════════════════════════════════════════════════════

# ── Entorno ──────────────────────────────────────────────
# Valores: local | test | production
APP_ENV=production
APP_URL=https://www.mastercodeweb.com

# ── API Keys Stripe ──────────────────────────────────────
# TEST:  sk_test_... / pk_test_...  (Dashboard → Developers → API keys)
# LIVE:  sk_live_... / pk_live_...  (activar cuenta en producción primero)
STRIPE_SECRET_KEY=sk_test_PEGA_AQUI
STRIPE_PUBLIC_KEY=pk_test_PEGA_AQUI
STRIPE_WEBHOOK_SECRET=whsec_PEGA_AQUI

# ── URL del sitio ────────────────────────────────────────
SITE_URL=https://www.mastercodeweb.com

# ── Price IDs — Pago único (one-time) ────────────────────
# Stripe Dashboard → Products → tu producto → Price ID (price_...)
PRICE_BASICO=price_PEGA_AQUI
PRICE_PRO=price_PEGA_AQUI
PRICE_PREMIUM=price_PEGA_AQUI

# ── Price IDs — Mantenimiento mensual (subscription) ─────
PRICE_MANT_BASICO=price_PEGA_AQUI
PRICE_MANT_PRO=price_PEGA_AQUI
PRICE_MANT_PREMIUM=price_PEGA_AQUI

# ── Notificaciones ────────────────────────────────────────
OWNER_EMAIL=tu@email.com

# ── Resend (transactional email) ──────────────────────────
# Dashboard → API Keys → Create → Send access only
# Dominio mastercodeweb.com debe estar verificado en Resend
RESEND_API_KEY=re_PEGA_AQUI

# ── Cloudflare Turnstile ──────────────────────────────────
# Dejar vacío o con el placeholder para modo fail-open (sin verificación server-side)
TURNSTILE_SECRET=REPLACE_WITH_YOUR_TURNSTILE_SECRET
