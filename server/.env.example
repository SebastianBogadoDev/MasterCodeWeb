# =====================================================
# MASTERCODEWEB · Variables de entorno
# ─────────────────────────────────────────────────
# 1. cp .env.example .env
# 2. Rellena los valores reales
# 3. NUNCA subas .env al repositorio (.gitignore)
# =====================================================

# ── Servidor ─────────────────────────────────────
PORT=3000
NODE_ENV=development        # development | production

# ── Frontend URL (redirecciones de Stripe) ───────
# Local:       http://127.0.0.1:5500
# Producción:  https://www.mastercodeweb.com
BASE_URL=http://127.0.0.1:5500

# ── Stripe · Claves API ──────────────────────────
# Dashboard → Developers → API keys
# sk_test_... en desarrollo · sk_live_... en producción
STRIPE_SECRET_KEY=

# ── Stripe · Webhook secret ──────────────────────
# Dashboard → Developers → Webhooks → tu endpoint → Signing secret
# En local con Stripe CLI:
#   stripe listen --forward-to localhost:3000/api/webhooks/stripe
#   (el CLI imprime el whsec_... al arrancar)
STRIPE_WEBHOOK_SECRET=

# ── Stripe · Price IDs (pagos únicos) ────────────
# Dashboard → Products → tu producto → clic en el precio → "Price ID"
# Formato: price_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_PRICE_BASICO=
STRIPE_PRICE_PROFESIONAL=
STRIPE_PRICE_PREMIUM=

# ── Stripe · Price IDs (suscripciones / cuotas) ──
# Estos precios deben ser RECURRENTES (monthly) en Stripe
# Dashboard → Products → nuevo producto → "Recurring" → mensual
STRIPE_PRICE_BASICO_CUOTAS=
STRIPE_PRICE_PROFESIONAL_CUOTAS=
STRIPE_PRICE_PREMIUM_CUOTAS=

# ── Stripe · Price IDs (mantenimiento mensual) ───
# Estos precios deben ser RECURRENTES (monthly) en Stripe
# Dashboard → Products → nuevo producto → "Recurring" → mensual
STRIPE_PRICE_MANT_BASICO=
STRIPE_PRICE_MANT_PROFESIONAL=
STRIPE_PRICE_MANT_PREMIUM=


# ── Gmail · Notificaciones de leads ──────────────
# Usa App Password, NO la contraseña de la cuenta Google
# Instrucciones: https://support.google.com/accounts/answer/185833
GMAIL_USER=tu_email@gmail.com
GMAIL_PASSWORD=xxxx_xxxx_xxxx_xxxx
